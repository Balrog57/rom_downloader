# Copiez ce fichier vers .env puis renseignez uniquement les cles utiles.
# Le script charge automatiquement .env au demarrage.

# 1fichier API (optionnel)
ONE_FICHIER_API_KEY=

# AllDebrid API (optionnel)
ALLDEBRID_API_KEY=

# RealDebrid API (optionnel)
REALDEBRID_API_KEY=

# Archive.org S3 credentials (optionnel)
IA_S3_ACCESS_KEY=
IA_S3_SECRET_KEY=

# LoLROMs (optionnel)
# Si Cloudflare bloque les fichiers .7z, copiez ici le cookie d'une session navigateur valide.
LOLROMS_COOKIE=
LOLROMS_USER_AGENT=
# Fallback navigateur pour les .7z bloques par Cloudflare.
# Headless=0 ouvre Edge/Chromium et permet de valider la verification Cloudflare.
LOLROMS_BROWSER_HEADLESS=0
LOLROMS_BROWSER_MODE=native
LOLROMS_BROWSER_CHANNEL=msedge
LOLROMS_BROWSER_PROFILE=
LOLROMS_NATIVE_BROWSER_PROFILE=
LOLROMS_EDGE_PATH=
LOLROMS_BROWSER_DOWNLOAD_ATTEMPTS=3

# Dossier contenant libcrypto-1_1-x64.dll et libssl-1_1-x64.dll
# utile si le module Python libtorrent est installe mais ne charge pas sous Windows.
LIBTORRENT_DLL_DIR=

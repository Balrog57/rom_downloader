# Copiez ce fichier vers .env puis renseignez uniquement les cles utiles.
# Le script charge automatiquement .env au demarrage.

# 1fichier API (optionnel)
ONE_FICHIER_API_KEY=

# AllDebrid API (optionnel)
ALLDEBRID_API_KEY=

# RealDebrid API (optionnel)
REALDEBRID_API_KEY=

# Archive.org S3 credentials (optionnel)
IA_S3_ACCESS_KEY=
IA_S3_SECRET_KEY=

# Dossier contenant libcrypto-1_1-x64.dll et libssl-1_1-x64.dll
# utile si le module Python libtorrent est installe mais ne charge pas sous Windows.
LIBTORRENT_DLL_DIR=
